# =============================================================================
# LOCAL WINDOWS PC + REMOTE PostgreSQL (your setup)
# =============================================================================
# ERP runs on your Windows machine (npm start → http://localhost:3001)
# PostgreSQL runs on the remote server 202.164.150.65:27010
#
# Copy this file to .env and fill in your real username/password/database name.
# =============================================================================

LAELA_DB_ENGINE=postgres
PG_HOST=202.164.150.65
PG_PORT=27010
PG_USER=your_username
PG_PASSWORD=your_password
PG_DATABASE=laela_erp

PORT=3001
HOST=127.0.0.1

# Leave laela-api-base empty in index.html — local use only (/api on same machine)

# --- Optional: only if you also use GitHub Pages (erp.laela.online) ---
# CORS_ORIGINS=https://erp.laela.online
# HOST=0.0.0.0

# --- Local SQLite instead (no remote Postgres) ---
# LAELA_DB_ENGINE=sqlite
